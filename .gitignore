# ────────────────────────────────────────────────────────────────────────────
# GIT IGNORE: Chess Game Project
# Ignore files that should NOT be committed to git
# ────────────────────────────────────────────────────────────────────────────

# ────────────────────────────────────────────────────────────────────────────
# CLAUDE CODE & EDITOR
# ────────────────────────────────────────────────────────────────────────────
.claude/                    # Claude Code configuration
.vscode/                    # VS Code settings
.idea/                      # IntelliJ/WebStorm settings
*.swp                       # Vim swap files
*.swo                       # Vim swap files
*~                          # Backup files

# ────────────────────────────────────────────────────────────────────────────
# PROJECT DOCUMENTATION (Internal)
# Keep only README.md, other docs can be generated
# ────────────────────────────────────────────────────────────────────────────
STRUCTURE.md                # Internal architecture documentation
TODO.md                     # Internal TODO list
NOTES.md                    # Developer notes
CHANGELOG.md                # Version history (if not needed)

# ────────────────────────────────────────────────────────────────────────────
# CREDENTIALS & SECRETS
# Never commit credentials, API keys, passwords, etc.
# ────────────────────────────────────────────────────────────────────────────
.env                        # Environment variables (local)
.env.local                  # Local environment overrides
.env.*.local                # Environment files
*.key                       # Private keys
*.pem                       # Private keys
.secret                     # Secret files
secrets.json                # Secret configuration
credentials.json            # Credentials file
config.local.js             # Local config overrides

# ────────────────────────────────────────────────────────────────────────────
# DEPENDENCIES
# node_modules should not be committed (use package.json instead)
# ────────────────────────────────────────────────────────────────────────────
node_modules/              # NPM dependencies
package-lock.json           # Lock file (optional - some projects commit this)
yarn.lock                   # Yarn lock file
pnpm-lock.yaml             # PNPM lock file

# ────────────────────────────────────────────────────────────────────────────
# BUILD & DIST
# Compiled/generated files
# ────────────────────────────────────────────────────────────────────────────
dist/                      # Distribution files
build/                     # Build output
*.min.js                   # Minified files
*.min.css                  # Minified files
coverage/                  # Test coverage reports

# ────────────────────────────────────────────────────────────────────────────
# OS FILES
# Operating system specific files
# ────────────────────────────────────────────────────────────────────────────
.DS_Store                  # macOS folder metadata
.DS_Store?                 # macOS
._*                        # macOS resource forks
.Spotlight-V100            # macOS search index
.Trashes                   # macOS trash
ehthumbs.db               # Windows thumbnail cache
Thumbs.db                 # Windows thumbnail cache
desktop.ini               # Windows desktop config

# ────────────────────────────────────────────────────────────────────────────
# LOG FILES
# Runtime logs and temporary files
# ────────────────────────────────────────────────────────────────────────────
*.log                      # Log files
*.log.*                    # Versioned log files
npm-debug.log*             # NPM debug logs
yarn-debug.log*            # Yarn debug logs
yarn-error.log*            # Yarn error logs
lerna-debug.log*           # Lerna debug logs
.pnpm-debug.log*           # PNPM debug logs

# ────────────────────────────────────────────────────────────────────────────
# TEMPORARY FILES
# Temporary and cache files
# ────────────────────────────────────────────────────────────────────────────
*.tmp                      # Temporary files
*.temp                     # Temporary files
*.cache                    # Cache files
.cache/                    # Cache directory
tmp/                       # Temporary directory
temp/                      # Temporary directory
*.bak                      # Backup files
*~                         # Backup files

# ────────────────────────────────────────────────────────────────────────────
# IDE GENERATED FILES
# Generated by IDEs that shouldn't be committed
# ────────────────────────────────────────────────────────────────────────────
.vscode/settings.json      # VSCode user settings
.vscode/launch.json        # VSCode debug config
.vscode/extensions.json    # VSCode extensions
.vscode/tasks.json         # VSCode tasks
.idea/                     # IntelliJ IDEA config
*.sublime-project          # Sublime project files
*.sublime-workspace        # Sublime workspace files
.project                   # Eclipse project file
.classpath                 # Eclipse classpath
.settings/                 # Eclipse settings

# ────────────────────────────────────────────────────────────────────────────
# PERSONAL DEVELOPER FILES
# Don't commit personal notes or settings
# ────────────────────────────────────────────────────────────────────────────
.my-notes/                 # Personal notes directory
my-*.md                    # Personal markdown files
personal/                  # Personal folder
dev-notes.txt              # Development notes

# ────────────────────────────────────────────────────────────────────────────
# DATABASE FILES
# If using any local databases
# ────────────────────────────────────────────────────────────────────────────
*.db                       # SQLite database
*.sqlite                   # SQLite database
*.sqlite3                  # SQLite database
*.json.db                  # JSON database

# ────────────────────────────────────────────────────────────────────────────
# TEST FILES (Generated)
# Keep source test files, ignore generated test reports
# ────────────────────────────────────────────────────────────────────────────
coverage/                  # Coverage reports
.nyc_output/              # NYC coverage output
dist-test/                # Test distribution

# ────────────────────────────────────────────────────────────────────────────
# OLD/DEPRECATED FILES
# Keep only when necessary for migration purposes
# ────────────────────────────────────────────────────────────────────────────
home.html                   # Old single-file version (deprecated)
